# Environment target: local | azure | databricks
APP_ENV=local
LOG_FORMAT=console
LOG_LEVEL=DEBUG
LOG_SERVICE=dash-azure-prototype

# Auth mode: dev (local) | entra (Microsoft Entra ID in production)
AUTH_MODE=dev

# Shared DB URL used by web + worker
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/appdb

# Queue/backend (local Redis defaults)
CELERY_APP_NAME=dash_azure_prototype
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
