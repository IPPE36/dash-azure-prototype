APP_NAME=Suite
APP_VERSION=1.0
DEV=true
SECRET=fallback-secret
CLIENT_ID=fallback-client-id
CLIENT_SECRET=fallback-client-secret
TENANT_ID=fallback-tenant-id
AUTHORITY=https://login.microsoftonline.com/fallback-tenant-id
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/appdb
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
DB_BACKUP_ON_STARTUP=true
DB_BACKUP_DIR=./db_backups
DB_BACKUP_MAX_AGE_HOURS=168
